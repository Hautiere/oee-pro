# ── PostgreSQL (Docker) ───────────────────────────────────────────────────────
POSTGRES_USER=oee_user
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=oee_pro_db

# URL utilisée par FastAPI local (host.docker.internal si Mac/Windows, localhost si Linux)
DATABASE_URL=postgresql+asyncpg://oee_user:change_me_in_prod@localhost:5432/oee_pro_db

# ── Auth JWT ──────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
SECRET_KEY=change_me_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── App ───────────────────────────────────────────────────────────────────────
ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
